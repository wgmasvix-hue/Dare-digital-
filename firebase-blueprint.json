{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Information about a Google Workspace connected user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/userProfile" },
      "description": "User profiles"
    }
  }
}
