# .env.example
# Supabase Configuration
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Service Keys (Used in Supabase Edge Functions)
# Note: These should be set in the Supabase Dashboard -> Project Settings -> Edge Functions
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Hugging Face (Used for local AI features)
VITE_HF_API_KEY=your-huggingface-api-key

# Koha ILS Integration
VITE_KOHA_URL=https://koha.example.edu
VITE_KOHA_API_KEY=your-koha-api-key

# DARE Admin
VITE_DARE_ADMIN_TOKEN=your-admin-token

# Optional: API URL if using a custom backend
VITE_API_URL=
